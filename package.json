{
  "name": "piggyxp-frontend",
  "version": "0.8.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo run:android",
    "test": "jest --verbose --detectOpenHandles",
    "prebuild": "pnpm expo prebuild --clean",
    "build-preview": "npx --yes eas-cli@latest build -p android --profile preview",
    "update-preview": "npx --yes eas-cli@latest update --branch preview --message",
    "build-dev": "npx --yes eas-cli@latest build -p android --profile development",
    "update-dev": "npx --yes eas-cli@latest update --branch development --message",
    "build-production": "npx --yes eas-cli@latest build -p android --profile production",
    "update-production": "npx --yes eas-cli@latest update --branch production --message",
    "start": "pnpm expo start --dev-client",
    "ios": "expo run:ios"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "react-native-google-signin": "<rootDir>/__mocks__/react-native-google-signin/google-signin.js",
      "react-native-fbsdk-next": "<rootDir>/__mocks__/react-native-fbsdk-next.js",
      "expo-auth-session": "<rootDir>/__mocks__/expo-auth-session.js",
      "expo-constants": "<rootDir>/__mocks__/expo-constants.js",
      "expo-notifications": "<rootDir>/__mocks__/expo-notifications.js",
      "expo-linking": "<rootDir>/__mocks__/expo-linking.js",
      "expo-router": "<rootDir>/__mocks__/expo-router.tsx",
      "^Utils/(.*)$": "<rootDir>/src/Utils/$1",
      "^Features/(.*)$": "<rootDir>/src/Features/$1",
      "^Helpers/(.*)$": "<rootDir>/src/Helpers/$1",
      "^Components/(.*)$": "<rootDir>/src/Components/$1",
      "^Config/(.*)$": "<rootDir>/src/Config/$1",
      "^Contexts/(.*)$": "<rootDir>/src/Contexts/$1"
    }
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "axios": "~1.13.6",
    "expo": "~54.0.34",
    "expo-av": "^16.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.17",
    "expo-router": "^6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.17",
    "jwt-decode": "^4.0.0",
    "react": "19.1.0",
    "react-hook-form": "^7.76.1",
    "react-native": "0.81.5",
    "react-native-fbsdk-next": "^13.4.3",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.3.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "typescript": "~5.9.3"
  },
  "private": true
}
