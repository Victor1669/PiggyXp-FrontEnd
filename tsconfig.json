{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["jest", "react-native"],
    "paths": {
      "*": ["./src/*"],
      "@App/*": ["./app/*"],
      "@Auth/*": ["./src/Features/Auth/*"],
      "@Assets/*": [
        "./assets/*",
        "./src/Assets/*",
        "./src/Features/Auth/Assets/*",
        "./src/Features/Screens/Profile/Assets/*",
        "./src/Features/Screens/Swiper/Assets/*"
      ],
      "@Components/*": ["./src/Components/*"],
      "@Hooks/*": ["./src/Hooks/*", "./src/Features/Auth/Hooks/*"],
      "@Screens/*": ["./src/Features/Screens/*"],
      "@Styles/*": [
        "./src/Features/Auth/Styles/*",
        "./src/Features/Screens/Styles/*"
      ],
      "@Utils/*": ["./src/Utils/*"]
    }
  }
}
